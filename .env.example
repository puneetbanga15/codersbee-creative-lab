VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Perplexity API — powers the in-browser Python playground
VITE_PERPLEXITY_API_KEY=your_perplexity_key_here

# Summer Camp student credentials (server-side only — set in Netlify dashboard)
# Format: username:password,username2:password2
CAMP_USERS=student1:password1,student2:password2

# Summer Camp teacher credentials (server-side only — set in Netlify dashboard)
# Format: username:password  (multiple teachers: teacher1:pass1,teacher2:pass2)
# Teachers are redirected to /summer-camp/teacher after login
CAMP_TEACHERS=teacher:yourpassword

# HMAC secret for signing session tokens — use a long random string
CAMP_AUTH_SECRET=change-this-to-a-long-random-secret
